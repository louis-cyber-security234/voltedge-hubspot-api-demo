# VoltEdge RevOps Demo - Example Environment Variables
# This file is safe to commit because it contains placeholders only.
# Never commit a real .env file with live API keys, tokens or secrets.

HUBSPOT_PRIVATE_APP_TOKEN=your_hubspot_private_app_token_here
HUBSPOT_PORTAL_ID=your_hubspot_portal_id_here

N8N_BASE_URL=https://your-n8n-instance.example.com
N8N_WEBHOOK_SECRET=your_optional_webhook_secret_here

SLACK_WEBHOOK_URL=your_optional_slack_webhook_url_here

STRIPE_SECRET_KEY=your_optional_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_optional_stripe_webhook_secret_here

GOOGLE_ADS_CUSTOMER_ID=your_optional_google_ads_customer_id_here
GOOGLE_ADS_CONVERSION_ACTION_ID=your_optional_conversion_action_id_here
