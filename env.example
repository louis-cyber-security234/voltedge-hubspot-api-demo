# VoltEdge HubSpot API Demo - Example environment variables
# Copy this file to .env for local use only.
# Do not commit .env files containing real secrets.

# HubSpot
HUBSPOT_PRIVATE_APP_TOKEN=replace_me
HUBSPOT_PORTAL_ID=replace_me

# Stripe-style billing source
STRIPE_API_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me

# Ad platform conversion feedback
AD_PLATFORM_API_TOKEN=replace_me
GOOGLE_ADS_CUSTOMER_ID=replace_me
META_AD_ACCOUNT_ID=replace_me
LINKEDIN_AD_ACCOUNT_ID=replace_me

# Reporting output
SLACK_WEBHOOK_URL=replace_me
SLACK_CHANNEL_ID=replace_me

# n8n
N8N_BASE_URL=replace_me
N8N_WEBHOOK_SECRET=replace_me

# Demo controls
ENVIRONMENT=demo
SEND_LIVE_EVENTS=false
